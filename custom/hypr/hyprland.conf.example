# Hyprland configuration — omarchy-bootc skeleton
#
# This file is a starting-point placeholder.  It is staged at build time to
# /usr/share/omarchy/hypr/hyprland.conf.example and can be deployed by the
# first-boot script to ~/.config/hypr/hyprland.conf.
#
# For upstream Omarchy defaults see: https://github.com/basecamp/omarchy

# ── Monitor ───────────────────────────────────────────────────────────────────
# monitor=,preferred,auto,1

# ── Input ─────────────────────────────────────────────────────────────────────
